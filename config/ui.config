# UI 設定 / UI Configuration

# Default language: 
LANGUAGE=zh-TW

# Font size (px)
FONT_SIZE=14

# ── 各語言對應字型 ──
# 繁體中文
FONT_UI_zh-TW=Noto Sans TC
FONT_MONO_zh-TW=IBM Plex Mono

# English
FONT_UI_en=IBM Plex Sans
FONT_MONO_en=IBM Plex Mono

# 日本語
FONT_UI_ja=Noto Sans JP
FONT_MONO_ja=IBM Plex Mono

# ── Fallback（找不到語言對應時使用）──
FONT_UI=IBM Plex Sans
FONT_MONO=IBM Plex Mono